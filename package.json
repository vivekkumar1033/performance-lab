{
  "name": "@vivek-kumar/perf-lab",
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive web performance learning tool — diagnose real-world performance problems, apply fixes, and master Core Web Vitals",
  "license": "MIT",
  "keywords": [
    "web-performance",
    "core-web-vitals",
    "learning",
    "lcp",
    "cls",
    "inp",
    "react",
    "pagespeed"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./theme.css": "./src/perf-lab-theme.css",
    "./worker": {
      "import": "./dist/worker/perf-lab.worker.js"
    }
  },
  "files": [
    "dist",
    "src/perf-lab-theme.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "tsup",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.12",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^27.0.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.0.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^5.0.0",
    "framer-motion": "^12.0.0",
    "lucide-react": ">=0.400.0"
  },
  "packageManager": "yarn@1.22.22",
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true },
    "zustand": { "optional": true },
    "framer-motion": { "optional": true },
    "lucide-react": { "optional": true }
  }
}
